FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0";
    object      Phi;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    inlet
    {
        type            codedFixedValue;
        value           uniform 0;
        name            inletturgut;
        code            #{

          
            
			
			const scalar t = this->db().time().value();
            #include "$FOAM_CASE/constant/waveTurgut"
			
            
			
			 #};
    }
    outlet
    {
        type            fixedValue;
        value           uniform 0;
    }
    upper
    {
        type            waveCurrentPotential3D;
        shape           101;
        value           uniform 0;
    }
    lower
    {
        type            zeroGradient;
    }
    sphere
    {
        type            zeroGradient;
    }
    front
    {
        type            zeroGradient;
    }
    back
    {
        type            zeroGradient;
    }
}


